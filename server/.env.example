# Database (default: SQLite file keyauth.db in server/ directory)
# For MySQL: mysql+pymysql://root:password@localhost:3306/keyauth
# For PostgreSQL: postgresql://user:pass@localhost:5432/keyauth
DATABASE_URL=

# Security - CHANGE THESE IN PRODUCTION
SECRET_KEY=change-this-to-a-very-long-random-secret-key-at-least-32-chars
ENCRYPTION_KEY=0123456789abcdef0123456789abcdef

# Admin login
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# Discord Bot (optional - only needed if running the bot)
DISCORD_BOT_TOKEN=
